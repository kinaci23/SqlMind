{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=sqlmind;Username=postgres;Password=sqlmind123",
    "Redis": "localhost:6379"
  },

  "Jwt": {
    "Secret":   "sqlmind-dev-secret-key-minimum-32-chars!!",
    "Issuer":   "sqlmind",
    "Audience": "sqlmind-api"
  },

  "PolicyConfig": {
    "Rules": {
      "CRITICAL": [ "CreateTicket", "SendNotification", "RequestApproval" ],
      "HIGH":     [ "CreateTicket" ],
      "MEDIUM":   [ "WarnLog" ],
      "LOW":      [ "LogOnly" ]
    }
  },

  "Hangfire": {
    "WorkerCount": 4
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/analyze",
        "Period":   "1m",
        "Limit":    10
      },
      {
        "Endpoint": "POST:/api/v1/schema/ingest",
        "Period":   "1h",
        "Limit":    5
      },
      {
        "Endpoint": "GET:*",
        "Period":   "1m",
        "Limit":    60
      }
    ]
  },

  "IpRateLimitPolicies": {
    "IpRules": []
  }
}
