{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PolicyConfig": {
    "Rules": {
      "CRITICAL": [ "CreateTicket", "SendNotification", "RequestApproval" ],
      "HIGH":     [ "CreateTicket" ],
      "MEDIUM":   [ "WarnLog" ],
      "LOW":      [ "LogOnly" ]
    }
  }
}
